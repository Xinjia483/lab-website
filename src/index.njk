---
layout: layouts/base.njk
title: Home
permalink: /
---
{% set latestNews = news | sortNews %}

<section class="hero hero--home">
  <div class="card hero__media">
    <img src="{{ site.homeImage | withBaseUrl }}" alt="Portrait placeholder for {{ site.facultyName }}">
  </div>
  <div class="hero__content">
    <h1>{{ site.facultyName }}</h1>
    <p class="lede hero__affiliations">
      Associate Professor, Department of Computing Science, University of Alberta<br>
      <a href="https://cifar.ca/">Canada CIFAR AI Chair</a> and Fellow of the <a href="https://www.amii.ca/">Alberta Machine Intelligence Institute</a><br>
      Member of the <a href="https://rlai.ualberta.ca/">Reinforcement Learning and AI Lab (RLAI)</a><br>
      Fellow of the CIFAR Learning in Machine and Brains Program<br>
      Member of the College of New Scholars, Artists and Scientists in the Royal Society of Canada<br>
      CEO of <a href="https://rlcore.ai/">RLCore</a>
    </p>
    <p class="hero-links">
      <a href="{{ site.socialLinks[0].url | withBaseUrl }}">Google Scholar</a>
      <a href="{{ site.contact.profileLinks[0].url | withBaseUrl }}">Curriculum Vitae</a>
      <a href="{{ site.photoImage | withBaseUrl }}">Photo</a>
      <button type="button" class="hero-links__button" data-dialog-open="bio-dialog">Bio</button>
    </p>
  </div>
</section>

<section class="section section--research-focus">
  <h2>Research Focus of the Lab</h2>
  <div class="stack">
    {{ siteText.researchFocus | markdown | safe }}
  </div>
</section>

<section class="section">
  <h2>Latest news</h2>
  <div class="simple-list news-timeline">
    {% for item in latestNews %}
      {% if loop.index0 < 7 %}
        <article class="list-item">
          <p class="meta">{{ item.date }}</p>
          <p>
            {% if item.url %}
              <a href="{{ item.url | withBaseUrl }}">
                {{ item.title }}
              </a>
            {% else %}
              {{ item.title }}
            {% endif %}
          </p>
        </article>
      {% endif %}
    {% endfor %}
  </div>
</section>

<dialog class="bio-dialog" id="bio-dialog" aria-labelledby="bio-dialog-title">
  <div class="bio-dialog__inner">
    <div class="bio-dialog__head">
      <h2 id="bio-dialog-title">Bio</h2>
      <button type="button" class="bio-dialog__close" data-dialog-close aria-label="Close bio">&times;</button>
    </div>
    <div class="stack bio-dialog__body">
      {{ siteText.homeBio | markdown | safe }}
    </div>
  </div>
</dialog>

<section class="section section--about">
  <h2>About Me</h2>
  {{ siteText.aboutMe | markdown | safe }}
</section>

<script>
  (() => {
    const dialog = document.getElementById("bio-dialog");
    if (!dialog || typeof dialog.showModal !== "function") return;

    document.querySelectorAll('[data-dialog-open="bio-dialog"]').forEach((trigger) => {
      trigger.addEventListener("click", () => dialog.showModal());
    });

    dialog.querySelectorAll("[data-dialog-close]").forEach((closer) => {
      closer.addEventListener("click", () => dialog.close());
    });

    dialog.addEventListener("click", (event) => {
      const rect = dialog.getBoundingClientRect();
      const inside =
        event.clientX >= rect.left &&
        event.clientX <= rect.right &&
        event.clientY >= rect.top &&
        event.clientY <= rect.bottom;
      if (!inside) dialog.close();
    });
  })();
</script>
