---
layout: layouts/page.njk
title: Lab
eyebrow: Research Group
lede: Learn about the lab's research areas, current members, and alumni.
permalink: /lab/
---
<section class="section lab-overview">
  <div class="card lab-overview__photo">
    <img src="{{ site.groupPhoto | withBaseUrl }}" alt="Group photo placeholder for the lab">
  </div>
</section>

<section class="section lab-members-section">
  <h2>Current members</h2>
  <div class="member-grid member-roster">
    {% for member in members %}
      <article class="card member-card">
        <img src="{{ member.photo | withBaseUrl }}" alt="Profile placeholder for {{ member.name }}">
        <div class="member-card__body">
          <h3>{{ member.name }}</h3>
          <p class="meta">{{ member.role }}{% if member.coSupervisor %} · co-supervised {{ member.coSupervisor }}{% endif %}</p>
          <ul class="tag-list">
            {% for area in member.researchAreas %}
              <li class="tag">{{ area }}</li>
            {% endfor %}
          </ul>
          {% if member.website or member.googleScholar %}
            <p class="member-links">
              {% if member.website %}
                <a href="{{ member.website | withBaseUrl }}">Personal website</a>
              {% endif %}
              {% if member.website and member.googleScholar %} · {% endif %}
              {% if member.googleScholar %}
                <a href="{{ member.googleScholar | withBaseUrl }}">Google Scholar</a>
              {% endif %}
            </p>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>

<section class="section">
  <h2>Alumni</h2>
  <div class="alumni-list">
    {% for alum in alumni %}
      <article class="alum">
        <div class="alum__years">{% if alum.joiningYear and alum.endingYear %}{{ alum.joiningYear }}&#8202;&ndash;&#8202;{{ alum.endingYear }}{% elif alum.endingYear %}{{ alum.endingYear }}{% elif alum.joiningYear %}{{ alum.joiningYear }}{% else %}&mdash;{% endif %}</div>
        <div class="alum__body">
          <p class="alum__name">{{ alum.name }}</p>
          <p class="alum__role">{{ alum.role }}{% if alum.coSupervisor %} &middot; co-supervised with {{ alum.coSupervisor }}{% endif %}</p>
          {% if alum.currentRole or alum.currentOrganization or alum.website %}
            <p class="alum__now">
              {%- if alum.currentRole or alum.currentOrganization -%}
                <span class="alum__now-label">Now</span>{% if alum.currentRole %}{{ alum.currentRole }}{% endif %}{% if alum.currentOrganization %}{% if alum.currentRole %}, {% endif %}{{ alum.currentOrganization }}{% endif %}
              {%- endif -%}
              {%- if alum.website -%}
                {% if alum.currentRole or alum.currentOrganization %} <span class="alum__sep">&middot;</span> {% endif %}<a href="{{ alum.website | withBaseUrl }}">website</a>
              {%- endif -%}
            </p>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>

<section class="section section--lab-links">
  <h2>Lab Photos</h2>
  <p><a href="{{ site.groupPhoto | withBaseUrl }}">Group picture from 2026</a></p>
  <p><a href="{{ '/assets/images/groups/martha-white-group-2023.png' | withBaseUrl }}">Group picture from 2023</a></p>
  <p><a href="{{ '/assets/images/groups/martha-white-group-2020.jpg' | withBaseUrl }}">Group picture from 2020</a></p>
  <p><a href="{{ '/assets/images/groups/martha-white-group-2019.jpg' | withBaseUrl }}">Group picture from 2019</a></p>
</section>
